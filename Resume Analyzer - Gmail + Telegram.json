    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const subject = $json.subject || $json.headers?.subject || '';\nconst fromHeader = $json.headers?.from || $json.from?.value?.[0]?.address || $json.from || '';\nconst match = String(fromHeader).match(/<(.+?)>/);\nconst recipientEmail = match?.[1] || String(fromHeader).trim();\n\nconst parts = String(subject).split('-');\nconst jobRole = parts.length > 1 ? parts.slice(1).join('-').trim() : 'General Software Engineer';\n\nconst supported = {\n  'application/pdf': 'pdf',\n  'text/plain': 'txt',\n  'application/vnd.openxmlformats-officedocument.wordprocessingml.document': 'docx',\n};\n\nlet selectedKey = null;\nlet fileType = '';\nlet fileName = '';\nlet mimeType = '';\n\nfor (const key of Object.keys($binary || {})) {\n  const item = $binary[key];\n  const name = item.fileName || key;\n  const mime = item.mimeType || '';\n  const ext = name.split('.').pop()?.toLowerCase() || '';\n  const type = supported[mime] || (['pdf', 'txt', 'docx'].includes(ext) ? ext : '');\n  if (type) {\n    selectedKey = key;\n    fileType = type;\n    fileName = name;\n    mimeType = mime;\n    break;\n  }\n}\n\nif (!selectedKey) {\n  return {\n    json: {\n      source: 'gmail',\n      action: 'unsupported_file',\n      recipientEmail,\n      jobRole,\n      subject,\n      message: 'Please attach a resume as PDF, DOCX, or TXT. Put the target role after a dash in the email subject, for example: Resume - Backend Developer Intern.'\n    }\n  };\n}\n\nreturn {\n  json: {\n    source: 'gmail',\n    action: 'analyze',\n    recipientEmail,\n    jobRole,\n    subject,\n    fileName,\n    mimeType,\n    fileType\n  },\n  binary: {\n    resumeFile: $binary[selectedKey]\n  }\n};"
      },
